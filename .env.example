UPSTAGE_API_KEY=your_solar_api_key_here

# Solar 완전 장애 시 대체 모델(선택). 비워두면 Mock 규칙으로 바로 폴백.
FALLBACK_MODEL=gemini/gemini-flash-latest
GEMINI_API_KEY=

# Supabase (선택) — 학생 프로필/진척도 저장. 비워두면 진척도 저장 비활성화.
SUPABASE_URL=
SUPABASE_KEY=

# Langfuse (선택) — LLM 호출 트레이싱. 비워두면 트레이싱 비활성화.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
